{
  "identifier": "default",
  "description": "Default capability for PREV Player",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "dialog:allow-open",
    "fs:read-all",
    {
      "identifier": "fs:allow-stat",
      "allow": [{ "path": "**" }]
    },
    "opener:default",
    "opener:allow-open-url",
    "updater:default",
    "process:default"
  ]
}
